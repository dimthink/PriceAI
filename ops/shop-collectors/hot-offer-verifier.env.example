# Copy to /etc/priceai/hot-offer-verifier.env on each collector node.
# Keep shadow mode until the observed price, stock and status diffs are reviewed.
PRICEAI_HOT_VERIFY_MODE=shadow
PRICEAI_HOT_VERIFY_NODE_COUNT=2
PRICEAI_HOT_VERIFY_NODE_INDEX=0
PRICEAI_COLLECTOR_NODE_ID=hangzhou-hot-1
PRICEAI_COLLECTOR_NODE_NAME=Hangzhou hot verifier
PRICEAI_COLLECTOR_NODE_REGION=cn-hangzhou

# Set to 600000 only after write mode is enabled. A healthy peer keeps its
# candidates fresh; a stale peer shard is taken over after ten minutes.
PRICEAI_HOT_VERIFY_TAKEOVER_AFTER_MS=0
PRICEAI_HOT_VERIFY_MAX_DURATION_MS=270000
PRICEAI_HOT_VERIFY_RECENT_REUSE_MS=90000
PRICEAI_HOT_VERIFY_REQUEST_DELAY_MS=1500
PRICEAI_HOT_VERIFY_PROXY_REUSE_TTL_MS=240000

# Proxy credentials and provider URL remain in /etc/priceai/collector-proxy.env.
# This list controls which ShopApi hosts may use proxy fallback.
PRICEAI_SHOPAPI_PROXY_HOSTS=www.ldxp.cn,pay.ldxp.cn,ldxp.cn,pay.qxvx.cn,catfk.com
